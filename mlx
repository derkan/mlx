#!/usr/bin/env bash
set -euo pipefail

VERSION="0.3.0"
SCRIPT_NAME="mlx"
APP_NAME="mlx-cli"

MLX_HOME_DEFAULT="$HOME/.local/share/$APP_NAME"
MLX_CONFIG_DIR_DEFAULT="$HOME/.config/$APP_NAME"
MLX_HOME="${MLX_HOME:-$MLX_HOME_DEFAULT}"
MLX_CONFIG_DIR="${MLX_CONFIG_DIR:-$MLX_CONFIG_DIR_DEFAULT}"
MLX_CONFIG_FILE="${MLX_CONFIG_FILE:-$MLX_CONFIG_DIR/config.sh}"

mkdir -p "$MLX_HOME" "$MLX_CONFIG_DIR"

if [[ -f "$MLX_CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$MLX_CONFIG_FILE"
fi

MLX_HOME="${MLX_HOME:-$MLX_HOME_DEFAULT}"
MLX_CONFIG_DIR="${MLX_CONFIG_DIR:-$MLX_CONFIG_DIR_DEFAULT}"
MLX_VENV="${MLX_VENV:-$MLX_HOME/venv}"
MLX_BIN_DIR="${MLX_BIN_DIR:-$MLX_HOME/bin}"
MLX_LOG_DIR="${MLX_LOG_DIR:-$MLX_HOME/log}"
MLX_RUN_DIR="${MLX_RUN_DIR:-$MLX_HOME/run}"
MLX_MODELS_DIR="${MLX_MODELS_DIR:-$MLX_HOME/models}"
MLX_CACHE_DIR="${MLX_CACHE_DIR:-$MLX_HOME/cache}"
MLX_REGISTRY_FILE="${MLX_REGISTRY_FILE:-$MLX_MODELS_DIR/registry.tsv}"
MLX_PID_FILE="${MLX_PID_FILE:-$MLX_RUN_DIR/server.pid}"
MLX_STATE_FILE="${MLX_STATE_FILE:-$MLX_RUN_DIR/server.state}"
MLX_LOG_FILE="${MLX_LOG_FILE:-$MLX_LOG_DIR/server.log}"
MLX_SEARCH_CACHE_TTL="${MLX_SEARCH_CACHE_TTL:-21600}"
MLX_DEFAULT_MODEL="${MLX_DEFAULT_MODEL:-mlx-community/Llama-3.2-3B-Instruct-4bit}"
MLX_HOST="${MLX_HOST:-127.0.0.1}"
MLX_PORT="${MLX_PORT:-11435}"
MLX_DEFAULT_CTX="${MLX_DEFAULT_CTX:-8192}"
MLX_DEFAULT_MAX_KV_SIZE="${MLX_DEFAULT_MAX_KV_SIZE:-4096}"
MLX_DEFAULT_PYTHON="${MLX_DEFAULT_PYTHON:-3.12.10}"

mkdir -p "$MLX_BIN_DIR" "$MLX_LOG_DIR" "$MLX_RUN_DIR" "$MLX_MODELS_DIR" "$MLX_CACHE_DIR"
[[ -f "$MLX_REGISTRY_FILE" ]] || : > "$MLX_REGISTRY_FILE"

usage() {
  cat <<USAGE
$SCRIPT_NAME $VERSION

Usage:
  $SCRIPT_NAME install [--python VERSION] [--default-model MODEL] [--force]
  $SCRIPT_NAME uninstall [--purge-models] [--purge-config] [--yes]
  $SCRIPT_NAME add model -m MODEL [--alias NAME]
  $SCRIPT_NAME pull -m MODEL [--alias NAME] [--trust-remote-code]
  $SCRIPT_NAME rm -m MODEL [--yes]
  $SCRIPT_NAME ls [--json]
  $SCRIPT_NAME search [--fit] [--best] [--json] [--limit N] [--author ORG] [--community-only] [--query TEXT] [--ram GB] [--refresh]
  $SCRIPT_NAME serve [-m MODEL] [--host HOST] [--port PORT] [--max-kv-size N] [--foreground] [--replace] [--trust-remote-code]
  $SCRIPT_NAME stop [--force]
  $SCRIPT_NAME status
  $SCRIPT_NAME ps
  $SCRIPT_NAME logs
  $SCRIPT_NAME chat [-m MODEL] [--system TEXT] [--temperature FLOAT] [--max-kv-size N] [--trust-remote-code]
  $SCRIPT_NAME generate -m MODEL -p PROMPT [--max-kv-size N] [--trust-remote-code]
  $SCRIPT_NAME run {claude|codex|free-code} [-m MODEL]
  $SCRIPT_NAME set-default -m MODEL
  $SCRIPT_NAME doctor
  $SCRIPT_NAME env
  $SCRIPT_NAME version
  $SCRIPT_NAME help
USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

note() {
  echo "==> $*" >&2
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

is_macos() { [[ "$(uname -s)" == "Darwin" ]]; }
is_arm64() { [[ "$(uname -m)" == "arm64" ]]; }

ensure_dirs() {
  mkdir -p "$MLX_HOME" "$MLX_CONFIG_DIR" "$MLX_BIN_DIR" "$MLX_LOG_DIR" "$MLX_RUN_DIR" "$MLX_MODELS_DIR" "$MLX_CACHE_DIR"
  [[ -f "$MLX_REGISTRY_FILE" ]] || : > "$MLX_REGISTRY_FILE"
}

write_config() {
  ensure_dirs
  cat > "$MLX_CONFIG_FILE" <<CFG
MLX_HOME="$MLX_HOME"
MLX_CONFIG_DIR="$MLX_CONFIG_DIR"
MLX_VENV="$MLX_VENV"
MLX_BIN_DIR="$MLX_BIN_DIR"
MLX_LOG_DIR="$MLX_LOG_DIR"
MLX_RUN_DIR="$MLX_RUN_DIR"
MLX_MODELS_DIR="$MLX_MODELS_DIR"
MLX_CACHE_DIR="$MLX_CACHE_DIR"
MLX_REGISTRY_FILE="$MLX_REGISTRY_FILE"
MLX_PID_FILE="$MLX_PID_FILE"
MLX_STATE_FILE="$MLX_STATE_FILE"
MLX_LOG_FILE="$MLX_LOG_FILE"
MLX_DEFAULT_MODEL="$MLX_DEFAULT_MODEL"
MLX_HOST="$MLX_HOST"
MLX_PORT="$MLX_PORT"
MLX_DEFAULT_CTX="$MLX_DEFAULT_CTX"
MLX_DEFAULT_MAX_KV_SIZE="$MLX_DEFAULT_MAX_KV_SIZE"
MLX_DEFAULT_PYTHON="$MLX_DEFAULT_PYTHON"
MLX_SEARCH_CACHE_TTL="$MLX_SEARCH_CACHE_TTL"
CFG
}

venv_python() {
  echo "$MLX_VENV/bin/python"
}

venv_entry() {
  echo "$MLX_VENV/bin/$1"
}

require_install() {
  [[ -x "$(venv_python)" ]] || die "mlx is not installed yet. Run: $SCRIPT_NAME install"
}

py_exec() {
  require_install
  "$(venv_python)" "$@"
}

py_inline() {
  require_install
  "$(venv_python)" - "$@"
}

get_total_ram_gb() {
  if is_macos; then
    python3 - <<'PY'
import subprocess
mem = int(subprocess.check_output(["sysctl", "-n", "hw.memsize"]).decode().strip())
print(mem / (1024**3))
PY
  else
    python3 - <<'PY'
import os
pages = os.sysconf('SC_PHYS_PAGES')
ps = os.sysconf('SC_PAGE_SIZE')
print((pages * ps) / (1024**3))
PY
  fi
}

registry_resolve_model() {
  local key="$1"
  local line model alias
  while IFS=$'\t' read -r alias model _rest; do
    [[ -z "$alias" ]] && continue
    if [[ "$alias" == "$key" || "$model" == "$key" ]]; then
      echo "$model"
      return 0
    fi
  done < "$MLX_REGISTRY_FILE"
  echo "$key"
}

registry_upsert() {
  local alias="$1" model="$2" is_default="$3" trust="$4" used_at="$5" notes="$6"
  local tmp
  tmp="$(mktemp)"
  awk -F '\t' -v a="$alias" -v m="$model" 'BEGIN{OFS="\t"} $1!=a && $2!=m {print $0}' "$MLX_REGISTRY_FILE" > "$tmp" || true
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$alias" "$model" "$is_default" "$trust" "$used_at" "$notes" >> "$tmp"
  mv "$tmp" "$MLX_REGISTRY_FILE"
}

registry_remove() {
  local key="$1"
  local tmp
  tmp="$(mktemp)"
  awk -F '\t' -v k="$key" 'BEGIN{OFS="\t"} $1!=k && $2!=k {print $0}' "$MLX_REGISTRY_FILE" > "$tmp" || true
  mv "$tmp" "$MLX_REGISTRY_FILE"
}

registry_get_default() {
  local alias model defv
  while IFS=$'\t' read -r alias model defv _rest; do
    [[ "$defv" == "1" ]] && { echo "$model"; return 0; }
  done < "$MLX_REGISTRY_FILE"
  echo "$MLX_DEFAULT_MODEL"
}

registry_set_default() {
  local target="$1" resolved tmp alias model defv trust used_at notes
  resolved="$(registry_resolve_model "$target")"
  tmp="$(mktemp)"
  while IFS=$'\t' read -r alias model defv trust used_at notes; do
    [[ -z "$alias$model" ]] && continue
    if [[ "$model" == "$resolved" || "$alias" == "$target" ]]; then
      printf '%s\t%s\t1\t%s\t%s\t%s\n' "$alias" "$model" "$trust" "$used_at" "$notes" >> "$tmp"
    else
      printf '%s\t%s\t0\t%s\t%s\t%s\n' "$alias" "$model" "$trust" "$used_at" "$notes" >> "$tmp"
    fi
  done < "$MLX_REGISTRY_FILE"
  mv "$tmp" "$MLX_REGISTRY_FILE"
}

server_running() {
  [[ -f "$MLX_PID_FILE" ]] || return 1
  local pid
  pid="$(cat "$MLX_PID_FILE" 2>/dev/null || true)"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

cmd_install() {
  local python_version="$MLX_DEFAULT_PYTHON"
  local force="0"
  local default_model="$MLX_DEFAULT_MODEL"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --python) python_version="$2"; shift 2 ;;
      --default-model) default_model="$2"; shift 2 ;;
      --force) force="1"; shift ;;
      *) die "Unknown option for install: $1" ;;
    esac
  done

  is_macos || die "This script currently targets macOS."
  is_arm64 || die "This script requires Apple Silicon (arm64)."
  need_cmd bash
  need_cmd curl

  if ! command -v brew >/dev/null 2>&1; then
    die "Homebrew is required. Install it from https://brew.sh"
  fi

  if ! command -v pyenv >/dev/null 2>&1; then
    note "Installing pyenv via Homebrew"
    brew install pyenv
  fi

  export PYENV_ROOT="${PYENV_ROOT:-$HOME/.pyenv}"
  export PATH="$PYENV_ROOT/bin:$PATH"
  eval "$(pyenv init - bash)"

  if ! pyenv versions --bare | grep -Fxq "$python_version"; then
    note "Installing Python $python_version via pyenv"
    pyenv install "$python_version"
  fi

  ensure_dirs
  MLX_DEFAULT_PYTHON="$python_version"
  MLX_DEFAULT_MODEL="$default_model"

  if [[ -d "$MLX_VENV" && "$force" != "1" ]]; then
    die "Virtualenv already exists at $MLX_VENV. Use --force to recreate it."
  fi

  if [[ "$force" == "1" ]]; then
    rm -rf "$MLX_VENV"
  fi

  note "Creating virtualenv at $MLX_VENV"
  pyenv shell "$python_version"
  python -m venv "$MLX_VENV"

  note "Installing packages"
  "$MLX_VENV/bin/python" -m pip install --upgrade pip setuptools wheel
  "$MLX_VENV/bin/python" -m pip install --upgrade mlx-lm huggingface_hub

  write_config
  note "Installed."
  echo "Default model: $MLX_DEFAULT_MODEL"
  echo "Venv: $MLX_VENV"
}

cmd_uninstall() {
  local purge_models="0"
  local purge_config="0"
  local yes="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --purge-models) purge_models="1"; shift ;;
      --purge-config) purge_config="1"; shift ;;
      --yes) yes="1"; shift ;;
      *) die "Unknown option for uninstall: $1" ;;
    esac
  done
  if [[ "$yes" != "1" ]]; then
    die "Refusing to uninstall without --yes"
  fi
  if server_running; then
    cmd_stop
  fi
  rm -rf "$MLX_VENV" "$MLX_RUN_DIR" "$MLX_LOG_DIR" "$MLX_CACHE_DIR"
  if [[ "$purge_models" == "1" ]]; then
    rm -rf "$MLX_MODELS_DIR"
  fi
  if [[ "$purge_config" == "1" ]]; then
    rm -rf "$MLX_CONFIG_DIR"
  fi
  note "Uninstalled managed runtime."
}

cmd_add() {
  [[ $# -ge 1 ]] || die "Usage: $SCRIPT_NAME add model -m MODEL [--alias NAME]"
  local sub="$1"; shift
  case "$sub" in
    model)
      local model="" alias="" now
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -m|--model) model="$2"; shift 2 ;;
          --alias) alias="$2"; shift 2 ;;
          *) die "Unknown option for add model: $1" ;;
        esac
      done
      [[ -n "$model" ]] || die "Model is required"
      [[ -n "$alias" ]] || alias="$(basename "$model")"
      now="$(date -u +%FT%TZ)"
      registry_upsert "$alias" "$model" "0" "0" "$now" ""
      echo "Added: $alias -> $model"
      ;;
    *) die "Unknown add subcommand: $sub" ;;
  esac
}

cmd_pull() {
  require_install
  local model="" alias="" trust="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--model) model="$2"; shift 2 ;;
      --alias) alias="$2"; shift 2 ;;
      --trust-remote-code) trust="1"; shift ;;
      *) die "Unknown option for pull: $1" ;;
    esac
  done
  [[ -n "$model" ]] || die "Model is required: -m MODEL"
  [[ -n "$alias" ]] || alias="$(basename "$model")"
  note "Resolving and prefetching $model"
  py_inline "$model" "$trust" <<'PY'
import sys
from mlx_lm import load
model = sys.argv[1]
trust = sys.argv[2] == "1"
load(model, tokenizer_config={"trust_remote_code": True} if trust else None)
print(model)
PY
  registry_upsert "$alias" "$model" "0" "$trust" "$(date -u +%FT%TZ)" ""
  echo "Pulled: $alias -> $model"
}

cmd_rm() {
  require_install
  local model="" yes="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--model) model="$2"; shift 2 ;;
      --yes) yes="1"; shift ;;
      *) die "Unknown option for rm: $1" ;;
    esac
  done
  [[ -n "$model" ]] || die "Model is required"
  [[ "$yes" == "1" ]] || die "Refusing to remove without --yes"
  local resolved
  resolved="$(registry_resolve_model "$model")"
  registry_remove "$model"
  registry_remove "$resolved"
  py_inline "$resolved" <<'PY' || true
import os, shutil, sys
model = sys.argv[1]
slug = model.replace('/', '--')
roots = [
    os.path.expanduser('~/.cache/huggingface/hub'),
    os.path.expanduser('~/Library/Caches/huggingface/hub'),
]
for root in roots:
    if not os.path.isdir(root):
        continue
    for name in os.listdir(root):
        if slug in name:
            shutil.rmtree(os.path.join(root, name), ignore_errors=True)
print(model)
PY
  echo "Removed registry entry for: $resolved"
}

cmd_ls() {
  local as_json="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) as_json="1"; shift ;;
      *) die "Unknown option for ls: $1" ;;
    esac
  done
  if [[ "$as_json" == "1" ]]; then
    py_inline "$MLX_REGISTRY_FILE" <<'PY'
import csv, json, sys
rows=[]
with open(sys.argv[1], newline='') as f:
    for row in csv.reader(f, delimiter='\t'):
        if not row:
            continue
        alias, model, default, trust, used_at, notes = (row + [""]*6)[:6]
        rows.append({"alias":alias,"model":model,"default":default=="1","trust_remote_code":trust=="1","last_used":used_at,"notes":notes})
print(json.dumps(rows, indent=2))
PY
    return 0
  fi
  printf '%-24s %-52s %-7s %-7s %-22s\n' "ALIAS" "MODEL" "DEFAULT" "TRUST" "LAST_USED"
  printf '%-24s %-52s %-7s %-7s %-22s\n' "-----" "-----" "-------" "-----" "---------"
  while IFS=$'\t' read -r alias model defv trust used_at notes; do
    [[ -z "$alias$model" ]] && continue
    printf '%-24s %-52s %-7s %-7s %-22s\n' "$alias" "$model" "$defv" "$trust" "${used_at:-}"
  done < "$MLX_REGISTRY_FILE"
}

cmd_search() {
  require_install
  local fit="0" best="0" as_json="0" limit="30" author="" community_only="0" query="" ram="" refresh="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --fit) fit="1"; shift ;;
      --best) best="1"; fit="1"; shift ;;
      --json) as_json="1"; shift ;;
      --limit) limit="$2"; shift 2 ;;
      --author) author="$2"; shift 2 ;;
      --community-only) community_only="1"; shift ;;
      --query) query="$2"; shift 2 ;;
      --ram) ram="$2"; shift 2 ;;
      --refresh) refresh="1"; shift ;;
      *) die "Unknown option for search: $1" ;;
    esac
  done
  if [[ "$community_only" == "1" && -z "$author" ]]; then
    author="mlx-community"
  fi
  [[ -n "$ram" ]] || ram="$(get_total_ram_gb)"
  local author_key="all"
  [[ -n "$author" ]] && author_key="${author//\//_}"
  local qhash="all"
  [[ -n "$query" ]] && qhash="$(printf '%s' "$query" | shasum | awk '{print $1}')"
  local cache_file="$MLX_CACHE_DIR/search_${author_key}_${qhash}_${limit}.json"
  local now epoch age
  now="$(date +%s)"
  if [[ "$refresh" != "1" && -f "$cache_file" ]]; then
    epoch="$(stat -f %m "$cache_file" 2>/dev/null || echo 0)"
    age=$(( now - epoch ))
    if [[ "$age" -lt "$MLX_SEARCH_CACHE_TTL" ]]; then
      py_inline "$cache_file" "$as_json" "$fit" "$best" "$ram" <<'PY'
import json, sys
path, as_json, fit_only, best_only, ram = sys.argv[1], sys.argv[2]=='1', sys.argv[3]=='1', sys.argv[4]=='1', float(sys.argv[5])
items = json.load(open(path))
def rank(it):
    return (it.get('fit_rank', 9), -float(it.get('score', 0)), it.get('updated_days', 10**9), it.get('age_days', 10**9))
if fit_only:
    items = [x for x in items if x.get('fit_rank', 9) <= 1]
if best_only:
    items = sorted(items, key=rank)[:10]
else:
    items = sorted(items, key=rank)
if as_json:
    print(json.dumps(items, indent=2))
else:
    print(f"# showing cached results for ~{ram:.0f} GB RAM")
    print(f"{'MODEL':62} {'SRC':10} {'WT_GB':>7} {'FIT':>4} {'AGE':>8} {'UPD':>8} {'NOTES'}")
    for it in items:
        print(f"{it['id'][:62]:62} {it.get('source', '?')[:10]:10} {it.get('weights_gb', 0):7.1f} {it.get('fit', '?'):>4} {it.get('age_human', '?'):>8} {it.get('updated_human', '?'):>8} {it.get('notes', '')}")
PY
      return 0
    fi
  fi

  py_inline "$cache_file" "$author" "$query" "$limit" "$ram" "$fit" "$best" "$as_json" <<'PY'
import json, os, re, sys
from datetime import datetime, timezone
from huggingface_hub import HfApi

cache_file, author, query, limit, ram_s, fit_only, best_only, as_json = sys.argv[1:9]
limit = int(limit)
ram = float(ram_s)
fit_only = fit_only == '1'
best_only = best_only == '1'
as_json = as_json == '1'
api = HfApi(token=os.getenv('HF_TOKEN'))
PARAM_RE = re.compile(r'(?i)(\d+(?:\.\d+)?)\s*([bm])\b')

def parse_params(text: str):
    m = PARAM_RE.search(text or '')
    if not m:
        return None
    val = float(m.group(1))
    return val if m.group(2).lower() == 'b' else val / 1000.0

def age_human(days):
    if days is None:
        return '?'
    days = int(days)
    if days < 1:
        return 'today'
    if days < 30:
        return f'{days}d'
    if days < 365:
        return f'{days//30}mo'
    return f'{days//365}y'

def score_fit(weights_gb, params_b, tags, model_id):
    text = ' '.join(tags).lower() + ' ' + model_id.lower()
    q4 = any(k in text for k in ['4bit', '4-bit', 'int4', 'q4'])
    q8 = any(k in text for k in ['8bit', '8-bit', 'int8', 'q8'])
    est_need = weights_gb * (1.9 if q4 else 2.7 if q8 else 3.4)
    if params_b:
        est_need = max(est_need, params_b * (1.4 if q4 else 2.2 if q8 else 3.0))
    soft = ram * 0.72
    hard = ram * 0.90
    if est_need <= soft:
        return '✅', 0, round(100 - est_need, 2), est_need
    if est_need <= hard:
        return '⚠️', 1, round(80 - est_need, 2), est_need
    return '❌', 2, round(40 - est_need, 2), est_need

def is_mlx_model(model, tags):
    tags = [str(t).lower() for t in (tags or [])]
    if 'mlx' in tags or 'library:mlx' in tags:
        return True
    library_name = getattr(model, 'library_name', None)
    if library_name and str(library_name).lower() == 'mlx':
        return True
    model_id = getattr(model, 'id', '') or ''
    lowered = model_id.lower()
    return lowered.endswith('-mlx') or '-mlx-' in lowered

def fetch_models():
    params = dict(search=query or None, limit=limit, full=True, cardData=False)
    if author:
        params['author'] = author
    try:
        return list(api.list_models(filter='mlx', **params))
    except Exception:
        models = list(api.list_models(**params))
        return [m for m in models if is_mlx_model(m, getattr(m, 'tags', None))]

models = fetch_models()
items = []
now = datetime.now(timezone.utc)
for m in models:
    model_tags = list(getattr(m, 'tags', None) or [])
    if not is_mlx_model(m, model_tags):
        continue
    try:
        info = api.model_info(m.id, files_metadata=True)
    except Exception:
        continue
    siblings = getattr(info, 'siblings', None) or []
    tags = list(getattr(info, 'tags', None) or model_tags or [])
    if not is_mlx_model(m, tags):
        continue
    created = getattr(info, 'created_at', None) or getattr(info, 'createdAt', None) or getattr(m, 'created_at', None) or getattr(m, 'createdAt', None)
    updated = getattr(info, 'last_modified', None) or getattr(info, 'lastModified', None) or getattr(m, 'last_modified', None) or getattr(m, 'lastModified', None)
    weight_bytes = 0
    largest_bytes = 0
    for s in siblings:
        name = getattr(s, 'rfilename', '') or ''
        size = getattr(s, 'size', None)
        if size is None:
            lfs = getattr(s, 'lfs', None)
            if isinstance(lfs, dict):
                size = lfs.get('size')
        if not size:
            continue
        low = name.lower()
        if low.endswith(('.safetensors', '.bin', '.npz', '.mlx')) or 'model-' in low:
            weight_bytes += int(size)
            largest_bytes = max(largest_bytes, int(size))
    weights_gb = round(weight_bytes / (1024**3), 2) if weight_bytes else round(largest_bytes / (1024**3), 2)
    params_b = parse_params(m.id)
    fit, fit_rank, score, est_need = score_fit(weights_gb, params_b, tags, m.id)
    lower = m.id.lower() + ' ' + ' '.join(tags).lower()
    source = 'official' if m.id.startswith('mlx-community/') else 'community'
    notes = []
    if 'coder' in lower or 'code' in lower:
        notes.append('coding')
    if any(k in lower for k in ['4bit', '4-bit', 'int4', 'q4']):
        notes.append('4bit')
    if any(k in lower for k in ['8bit', '8-bit', 'int8', 'q8']):
        notes.append('8bit')
    if any(k in lower for k in ['trust-remote-code', 'remote-code']):
        notes.append('remote-code')
    age_days = max(0, (now - created).total_seconds() / 86400.0) if created else None
    updated_days = max(0, (now - updated).total_seconds() / 86400.0) if updated else None
    recency_bonus = 0
    if updated_days is not None:
        if updated_days <= 7:
            recency_bonus = 8
        elif updated_days <= 30:
            recency_bonus = 4
        elif updated_days <= 90:
            recency_bonus = 1
    score += recency_bonus + (3 if source == 'official' else 0)
    items.append({
        'id': m.id,
        'source': source,
        'params_b': params_b,
        'weights_gb': weights_gb,
        'fit': fit,
        'fit_rank': fit_rank,
        'score': score,
        'estimated_need_gb': round(est_need, 1),
        'created_at': created.isoformat() if created else None,
        'updated_at': updated.isoformat() if updated else None,
        'age_days': round(age_days, 1) if age_days is not None else None,
        'updated_days': round(updated_days, 1) if updated_days is not None else None,
        'age_human': age_human(age_days),
        'updated_human': age_human(updated_days),
        'downloads': getattr(info, 'downloads', None) or getattr(m, 'downloads', None),
        'likes': getattr(info, 'likes', None) or getattr(m, 'likes', None),
        'notes': ', '.join(notes),
    })

items = sorted(items, key=lambda x: (x['fit_rank'], -(x['score'] or 0), x['updated_days'] if x['updated_days'] is not None else 10**9, x['age_days'] if x['age_days'] is not None else 10**9, x['id']))
with open(cache_file, 'w') as f:
    json.dump(items, f, indent=2)
if fit_only:
    items = [x for x in items if x['fit_rank'] <= 1]
if best_only:
    items = items[:10]
if as_json:
    print(json.dumps(items, indent=2))
else:
    print(f"# detected RAM: {ram:.1f} GB")
    print(f"{'MODEL':62} {'SRC':10} {'WT_GB':>7} {'FIT':>4} {'AGE':>8} {'UPD':>8} {'NOTES'}")
    for it in items:
        print(f"{it['id'][:62]:62} {it.get('source', '?')[:10]:10} {it.get('weights_gb', 0):7.1f} {it.get('fit', '?'):>4} {it.get('age_human', '?'):>8} {it.get('updated_human', '?'):>8} {it.get('notes', '')}")
PY
}

cmd_serve() {
  require_install
  local model="$(registry_get_default)" host="$MLX_HOST" port="$MLX_PORT" max_kv="$MLX_DEFAULT_MAX_KV_SIZE" foreground="0" replace="0" trust="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--model) model="$2"; shift 2 ;;
      --host) host="$2"; shift 2 ;;
      --port) port="$2"; shift 2 ;;
      --max-kv-size) max_kv="$2"; shift 2 ;;
      --foreground) foreground="1"; shift ;;
      --replace) replace="1"; shift ;;
      --trust-remote-code) trust="1"; shift ;;
      *) die "Unknown option for serve: $1" ;;
    esac
  done
  model="$(registry_resolve_model "$model")"
  if server_running; then
    if [[ "$replace" == "1" ]]; then
      cmd_stop
    else
      die "Server already running. Use --replace or stop it first."
    fi
  fi
  local cmd=("$(venv_python)" -m mlx_lm.server --model "$model" --host "$host" --port "$port" --max-kv-size "$max_kv")
  if [[ "$trust" == "1" ]]; then
    cmd+=(--trust-remote-code)
  fi
  if [[ "$foreground" == "1" ]]; then
    exec "${cmd[@]}"
  fi
  note "Starting server for $model on $host:$port"
  nohup "${cmd[@]}" >> "$MLX_LOG_FILE" 2>&1 &
  echo $! > "$MLX_PID_FILE"
  printf 'model=%s\nhost=%s\nport=%s\n' "$model" "$host" "$port" > "$MLX_STATE_FILE"
  sleep 2
  if server_running; then
    echo "Started PID $(cat "$MLX_PID_FILE")"
  else
    die "Server failed to start. Check logs: $MLX_LOG_FILE"
  fi
}

cmd_stop() {
  local force="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force="1"; shift ;;
      *) die "Unknown option for stop: $1" ;;
    esac
  done
  server_running || { echo "Server not running"; return 0; }
  local pid
  pid="$(cat "$MLX_PID_FILE")"
  kill "$pid" 2>/dev/null || true
  sleep 2
  if kill -0 "$pid" 2>/dev/null; then
    if [[ "$force" == "1" ]]; then
      kill -9 "$pid" 2>/dev/null || true
    else
      die "Server still running. Retry with --force"
    fi
  fi
  rm -f "$MLX_PID_FILE" "$MLX_STATE_FILE"
  echo "Stopped"
}

cmd_status() {
  if server_running; then
    echo "running pid=$(cat "$MLX_PID_FILE")"
    [[ -f "$MLX_STATE_FILE" ]] && cat "$MLX_STATE_FILE"
  else
    echo "stopped"
  fi
}

cmd_ps() {
  if server_running; then
    ps -p "$(cat "$MLX_PID_FILE")" -o pid=,etime=,command=
  else
    echo "No mlx server process"
  fi
}

cmd_logs() {
  [[ -f "$MLX_LOG_FILE" ]] || die "Log file not found: $MLX_LOG_FILE"
  tail -n 100 "$MLX_LOG_FILE"
}

cmd_chat() {
  require_install
  local model="$(registry_get_default)" system_prompt="" temperature="" max_kv="$MLX_DEFAULT_MAX_KV_SIZE" trust="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--model) model="$2"; shift 2 ;;
      --system) system_prompt="$2"; shift 2 ;;
      --temperature) temperature="$2"; shift 2 ;;
      --max-kv-size) max_kv="$2"; shift 2 ;;
      --trust-remote-code) trust="1"; shift ;;
      *) die "Unknown option for chat: $1" ;;
    esac
  done
  model="$(registry_resolve_model "$model")"
  local cmd=("$(venv_python)" -m mlx_lm.chat --model "$model" --max-kv-size "$max_kv")
  [[ -n "$system_prompt" ]] && cmd+=(--system "$system_prompt")
  [[ -n "$temperature" ]] && cmd+=(--temperature "$temperature")
  [[ "$trust" == "1" ]] && cmd+=(--trust-remote-code)
  registry_upsert "$(basename "$model")" "$model" "0" "$trust" "$(date -u +%FT%TZ)" ""
  exec "${cmd[@]}"
}

cmd_generate() {
  require_install
  local model="" prompt="" max_kv="$MLX_DEFAULT_MAX_KV_SIZE" trust="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--model) model="$2"; shift 2 ;;
      -p|--prompt) prompt="$2"; shift 2 ;;
      --max-kv-size) max_kv="$2"; shift 2 ;;
      --trust-remote-code) trust="1"; shift ;;
      *) die "Unknown option for generate: $1" ;;
    esac
  done
  [[ -n "$model" && -n "$prompt" ]] || die "Usage: $SCRIPT_NAME generate -m MODEL -p PROMPT"
  model="$(registry_resolve_model "$model")"
  local cmd=("$(venv_python)" -m mlx_lm.generate --model "$model" --prompt "$prompt" --max-kv-size "$max_kv")
  [[ "$trust" == "1" ]] && cmd+=(--trust-remote-code)
  exec "${cmd[@]}"
}

cmd_run() {
  [[ $# -ge 1 ]] || die "Usage: $SCRIPT_NAME run {claude|codex|free-code} [-m MODEL]"
  local preset="$1"; shift
  local model="$(registry_get_default)"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--model) model="$2"; shift 2 ;;
      *) die "Unknown option for run: $1" ;;
    esac
  done
  case "$preset" in
    claude)
      cmd_chat -m "$model" --system "Be a careful reasoning assistant. Think in plans, explain tradeoffs, and keep code precise." --temperature 0.2
      ;;
    codex)
      cmd_chat -m "$model" --system "Be a terse coding assistant. Prefer patches, commands, and exact implementation details." --temperature 0.1
      ;;
    free-code)
      cmd_chat -m "$model" --system "Be a creative but grounded coding copilot. Explore options and then implement the strongest one." --temperature 0.4
      ;;
    *) die "Unknown preset: $preset" ;;
  esac
}

cmd_set_default() {
  local model=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m|--model) model="$2"; shift 2 ;;
      *) die "Unknown option for set-default: $1" ;;
    esac
  done
  [[ -n "$model" ]] || die "Model required"
  registry_set_default "$model"
  echo "Default set to $(registry_resolve_model "$model")"
}

cmd_doctor() {
  echo "system: $(uname -s) $(uname -m)"
  echo "ram_gb: $(printf '%.1f' "$(get_total_ram_gb)")"
  echo "brew: $(command -v brew || echo missing)"
  echo "pyenv: $(command -v pyenv || echo missing)"
  echo "venv_python: $(venv_python)"
  if [[ -x "$(venv_python)" ]]; then
    "$(venv_python)" - <<'PY'
import sys
print('python_version:', sys.version.split()[0])
try:
    import mlx_lm
    print('mlx_lm: ok')
except Exception as e:
    print('mlx_lm: fail', e)
try:
    import huggingface_hub
    print('huggingface_hub: ok')
except Exception as e:
    print('huggingface_hub: fail', e)
PY
  fi
  echo "hf_token: ${HF_TOKEN:+set}"
  echo "config: $MLX_CONFIG_FILE"
  echo "server: $(server_running && echo running || echo stopped)"
}

cmd_env() {
  cat <<ENVV
MLX_HOME=$MLX_HOME
MLX_CONFIG_DIR=$MLX_CONFIG_DIR
MLX_VENV=$MLX_VENV
MLX_REGISTRY_FILE=$MLX_REGISTRY_FILE
MLX_LOG_FILE=$MLX_LOG_FILE
MLX_PID_FILE=$MLX_PID_FILE
MLX_DEFAULT_MODEL=$MLX_DEFAULT_MODEL
MLX_HOST=$MLX_HOST
MLX_PORT=$MLX_PORT
MLX_DEFAULT_CTX=$MLX_DEFAULT_CTX
MLX_DEFAULT_MAX_KV_SIZE=$MLX_DEFAULT_MAX_KV_SIZE
HF_TOKEN=${HF_TOKEN:+set}
ENVV
}

main() {
  local cmd="${1:-help}"
  [[ $# -gt 0 ]] && shift || true
  case "$cmd" in
    install) cmd_install "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    add) cmd_add "$@" ;;
    pull) cmd_pull "$@" ;;
    rm) cmd_rm "$@" ;;
    ls) cmd_ls "$@" ;;
    search) cmd_search "$@" ;;
    serve) cmd_serve "$@" ;;
    stop) cmd_stop "$@" ;;
    status) cmd_status "$@" ;;
    ps) cmd_ps "$@" ;;
    logs) cmd_logs "$@" ;;
    chat) cmd_chat "$@" ;;
    generate) cmd_generate "$@" ;;
    run) cmd_run "$@" ;;
    set-default) cmd_set_default "$@" ;;
    doctor) cmd_doctor "$@" ;;
    env) cmd_env "$@" ;;
    version) echo "$VERSION" ;;
    help|-h|--help) usage ;;
    *) die "Unknown command: $cmd" ;;
  esac
}

main "$@"
